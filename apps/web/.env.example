# FILE: /apps/web/.env.local
# Copy this file to /apps/web/.env.local and fill in all values.
# NEVER commit this file to git — it's already in .gitignore.

# ── SUPABASE ──────────────────────────────────────────────────────────────────
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# SERVICE_ROLE_KEY — only used in Route Handlers, NEVER exposed to client
# From: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── GROQ ──────────────────────────────────────────────────────────────────────
# Free tier at https://console.groq.com
# Create account → API Keys → Create API Key
GROQ_API_KEY=gsk_...

# ── HUGGING FACE ──────────────────────────────────────────────────────────────
# Free tier at https://huggingface.co/settings/tokens
# Create a token with "Inference" permissions
HUGGINGFACE_API_KEY=hf_...

# ── APP ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
