# ── SUPABASE ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# SERVICE_ROLE_KEY — only used in Route Handlers
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── GROQ ──────────────────────────────────────────────────────────────────────
# Free tier at https://console.groq.com
# Create account → API Keys → Create API Key
GROQ_API_KEY=gsk_...

# ── HUGGING FACE ──────────────────────────────────────────────────────────────
# Free tier at https://huggingface.co/settings/tokens
# Create a token with "Inference" permissions
HUGGINGFACE_API_KEY=hf_...

# ── APP ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
