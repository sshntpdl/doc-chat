{
  "expo": {
    "name": "DocChat",
    "slug": "docchat",
    "version": "1.0.0",
    "scheme": "docchat",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0F172A",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "backgroundColor": "#0F172A",
      "bundleIdentifier": "com.docchat.app",
      "infoPlist": {
        "NSDocumentDirectoryUsageDescription": "DocChat needs access to pick document files."
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "pan",
      "backgroundColor": "#0F172A",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#4F46E5"
      },
      "package": "com.docchat.app",
      "permissions": ["READ_EXTERNAL_STORAGE"]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      "expo-font",
      "expo-splash-screen"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3a21722f-d911-4e3b-abff-2056d91c63c2"
      }
    }
  }
}
