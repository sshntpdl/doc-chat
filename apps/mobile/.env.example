# FILE: /apps/mobile/.env
# Copy to /apps/mobile/.env and fill in values.
# Expo only exposes vars prefixed with EXPO_PUBLIC_ to the app bundle.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Points to your Next.js dev server. For device testing use your machine's
# LAN IP instead of localhost (e.g. http://192.168.1.x:3000)
EXPO_PUBLIC_API_URL=http://localhost:3000
